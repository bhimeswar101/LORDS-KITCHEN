# Bhim Kitchen Environment Configuration
# Rename this file to '.env' and fill in your SMTP credentials to send real emails.

# The SMTP host of your email provider (e.g. smtp.gmail.com, smtp.sendgrid.net, smtp.resend.com)
SMTP_HOST=smtp.gmail.com

# SMTP Port (commonly 587 for TLS, or 465 for SSL)
SMTP_PORT=587

# Your email account username
SMTP_USER=your-email@gmail.com

# Your email account password (use an "App Password" if using Gmail)
SMTP_PASS=your-gmail-app-password

# Sender Address header (e.g. "Restaurant Support <noreply@yourdomain.com>")
SMTP_FROM="Bhim Kitchen Support" <your-email@gmail.com>
